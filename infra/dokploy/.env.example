# ── Chain home ────────────────────────────────────────────────────────────────
# Mount/copy your .minitia directory here on the VPS
MINITIA_HOME=/data/.minitia

# OPinit state dir (auto-created on first run)
OPINIT_HOME=/data/.opinit

# ── L1: Initia testnet ────────────────────────────────────────────────────────
L1_CHAIN_ID=initiation-2
L1_RPC_URL=https://rpc.testnet.initia.xyz:443
L1_GAS_PRICE=0.015uinit

# ── L2: kitpot-2 rollup ───────────────────────────────────────────────────────
L2_CHAIN_ID=kitpot-2

# ── OPinit bots ───────────────────────────────────────────────────────────────
# Set to "true" to enable executor + challenger alongside the node
RUN_OPINIT=true

# Required when RUN_OPINIT=true — mnemonics for each bot key
BRIDGE_EXECUTOR_MNEMONIC=clap remain shrimp help print collect piano hunt kingdom trade column stamp hope keen agree plug embrace tooth purity insane enroll frost aware corn
OUTPUT_SUBMITTER_MNEMONIC=aunt rubber term benefit derive planet muscle cannon taste wrap planet actual flock chest toward reflect company excess veteran comic divide diesel pilot grow
BATCH_SUBMITTER_MNEMONIC=evoke secret catalog cover daring enter never start liberty crowd salmon stamp stairs metal rather inherit click grab truck toward hurdle humble coconut rebel
CHALLENGER_MNEMONIC=power tiny rapid chunk slab piece humble tattoo sock doctor price flee oppose echo deposit ensure raise sound unlock bind bracket wisdom assume ladder
