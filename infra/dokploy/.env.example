# ── Chain home ────────────────────────────────────────────────────────────────
MINITIA_HOME=/data/.minitia
OPINIT_HOME=/data/.opinit

# ── L1: Initia testnet ────────────────────────────────────────────────────────
L1_CHAIN_ID=initiation-2
L1_RPC_URL=https://rpc.testnet.initia.xyz:443
L1_GAS_PRICE=0.015uinit

# ── L2: rollup chain ──────────────────────────────────────────────────────────
L2_CHAIN_ID=kitpot-2

# ── Contract auto-deployment ──────────────────────────────────────────────────
# true  = deploy contracts automatically after node starts (fresh init mode)
# false = deploy manually from local: forge script --rpc-url http://vps-ip:8545
AUTO_DEPLOY=false

# ── OPinit bots ───────────────────────────────────────────────────────────────
# true  = run executor + challenger (required for real L1-connected rollup)
# false = standalone node only (for local testing with fresh init chain)
RUN_OPINIT=true

# Mnemonics from: cat ~/.weave/config.json | jq '.common'
BRIDGE_EXECUTOR_MNEMONIC=word word word ...
OUTPUT_SUBMITTER_MNEMONIC=word word word ...
BATCH_SUBMITTER_MNEMONIC=word word word ...
CHALLENGER_MNEMONIC=word word word ...

# ── Restore existing rollup (VPS production mode) ─────────────────────────────
# Run these on your Mac to get the values:
#   base64 -i ~/.minitia/config/genesis.json | tr -d '\n'
#   base64 -i ~/.minitia/config/priv_validator_key.json | tr -d '\n'
#   base64 -i ~/.minitia/config/node_key.json | tr -d '\n'
#
# Then: docker exec -it <container> /setup.sh restore
GENESIS_B64=
VALIDATOR_KEY_B64=
NODE_KEY_B64=

# ── Fresh init mode (local testing only) ─────────────────────────────────────
# docker exec -it <container> /setup.sh init
# CHAIN_ID=kitpot-test-1
# MONIKER=kitpot-node
